# Policy file mounted in container (non-secret)
PII_GATEWAY_CONFIG_PATH=/etc/pii-gateway/config.yaml

# HTTP API auth (set one approach)
SANITIZE_HTTP_API_KEY=
# BASIC_AUTH_USER=
# BASIC_AUTH_PASSWORD=

# CORS (comma-separated origins, empty = disabled)
CORS_ALLOWED_ORIGINS=

# Outbound artifact storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/data/out
# S3-compatible (when STORAGE_BACKEND=s3)
# S3_ENDPOINT_URL=http://minio:9000
# S3_BUCKET=
# S3_PREFIX=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# File inbox when policy batch_file_ingest.mode=s3
# INBOX_S3_BUCKET=
# INBOX_S3_PREFIX=

# Postgres batch (read-only DSN recommended)
POSTGRES_BATCH_DSN=
# Cron for in-process scheduler (empty disables postgres cron job)
POSTGRES_BATCH_CRON=
# File inbox poll (seconds); also used by batch file job when enabled
BATCH_FILE_POLL_SECONDS=

# Internal job API (optional; protect at network edge)
INTERNAL_JOB_API_KEY=

# Demo fixtures instead of real Postgres (CI/demos)
BATCH_DEMO_FIXTURE=false

# Max CSV file size (bytes) for batch ingest
BATCH_CSV_MAX_BYTES=52428800

# State / cursor files (local backend)
GATEWAY_STATE_DIR=/data/state

# Tests / local dev: skip APScheduler startup
DISABLE_SCHEDULER=false
